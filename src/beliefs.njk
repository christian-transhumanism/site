{% set beliefThemes = ['Foundations', 'Longevity', 'Theology', 'AI', 'Embodiment', 'Ecology', 'Church', 'Ethics'] %}

<div class="container">
  <div class="row">
    <div class="col-md-8">
      <div class="belief-explorer">
        <header class="belief-explorer__header">
          <h1 class="page-header">Belief Explorer</h1>
          <p class="page-intro">CTA lives in a space with real disagreement, so this page maps core positions, recurring objections, and the questions that still deserve debate.</p>
        </header>

        <div class="belief-explorer__toolbar">
          <div class="btn-group btn-group-sm" role="group" aria-label="Belief topic filter">
            <button type="button" class="btn btn-default belief-filter active" data-filter="all">All</button>
            {% for theme in beliefThemes %}
            <button type="button" class="btn btn-default belief-filter" data-filter="{{ theme }}">{{ theme }}</button>
            {% endfor %}
          </div>
          <label for="belief-search" class="visually-hidden">Search belief topics</label>
          <input id="belief-search" class="form-control input-sm belief-explorer__search" type="search" placeholder="Search topics, positions, or objections" autocomplete="off">
        </div>

        <div class="belief-explorer__empty alert alert-info" style="display:none;">No topics match that filter.</div>

        <div class="belief-explorer__grid" id="belief-grid">
          {% for topic in beliefTopics %}
          {% set searchIndex = (topic.theme ~ ' ' ~ topic.title ~ ' ' ~ topic.position ~ ' ' ~ (topic.why | join(' ')) ~ ' ' ~ (topic.misunderstandings | join(' ')) ~ ' ' ~ topic.spectrum ~ ' ' ~ topic.open) | lower %}
          <article class="home-card belief-card" data-theme="{{ topic.theme }}" data-search="{{ searchIndex }}">
            <div class="belief-card__eyebrow">{{ topic.theme }}</div>
            <h2 class="belief-card__title">{{ topic.title }}</h2>
            <p class="belief-card__position"><strong>CTA’s position:</strong> {{ topic.position }}</p>

            <button type="button" class="btn btn-default btn-sm belief-card__toggle" aria-expanded="false">
              Explore this position
            </button>

            <div class="belief-card__details" hidden>
              <div class="belief-card__section">
                <h3>Why CTA leans this way</h3>
                <ul>
                  {% for item in topic.why %}
                  <li>{{ item }}</li>
                  {% endfor %}
                </ul>
              </div>

              <div class="belief-card__section">
                <h3>Common misunderstandings</h3>
                <ul>
                  {% for item in topic.misunderstandings %}
                  <li>{{ item }}</li>
                  {% endfor %}
                </ul>
              </div>

              <div class="belief-card__section">
                <h3>Where Christians may disagree</h3>
                <p>{{ topic.spectrum }}</p>
              </div>

              <div class="belief-card__section">
                <h3>Open question</h3>
                <p>{{ topic.open }}</p>
              </div>

              <div class="belief-card__section">
                <h3>Go deeper</h3>
                <p class="belief-card__links">
                  {% for link in topic.links %}
                  <a href="{{ link.url }}">{{ link.label }}</a>{% if not loop.last %} <span aria-hidden="true">·</span> {% endif %}
                  {% endfor %}
                </p>
              </div>
            </div>
          </article>
          {% endfor %}
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="well site-sidebar">
        {% include 'shared/sidebar_nav.njk' %}
      </div>
      <div class="well site-sidebar">
        <h4>How to use this page</h4>
        <p>Start with the topics that generate the most confusion, then follow the linked mission pages, wiki entries, and FAQ for more depth.</p>
        <p>This page maps CTA’s center of gravity. It does not claim that every member would answer every question in exactly the same way.</p>
      </div>
    </div>
  </div>
</div>

<script>
  (function(){
    var grid = document.getElementById('belief-grid');
    if (!grid) return;

    var cards = Array.prototype.slice.call(grid.querySelectorAll('.belief-card'));
    var buttons = Array.prototype.slice.call(document.querySelectorAll('.belief-filter'));
    var searchInput = document.getElementById('belief-search');
    var empty = document.querySelector('.belief-explorer__empty');
    var activeTheme = 'all';

    function normalize(value) {
      return (value || '').toLowerCase();
    }

    function applyFilters() {
      var query = normalize(searchInput && searchInput.value).trim();
      var any = false;

      cards.forEach(function(card) {
        var matchesTheme = activeTheme === 'all' || normalize(card.getAttribute('data-theme')) === normalize(activeTheme);
        var matchesQuery = !query || normalize(card.getAttribute('data-search')).indexOf(query) !== -1;
        var show = matchesTheme && matchesQuery;
        card.style.display = show ? '' : 'none';
        if (show) any = true;
      });

      if (empty) empty.style.display = any ? 'none' : '';
    }

    buttons.forEach(function(button) {
      button.addEventListener('click', function() {
        activeTheme = this.getAttribute('data-filter') || 'all';
        buttons.forEach(function(item) {
          item.classList.toggle('active', item === button);
        });
        applyFilters();
      });
    });

    cards.forEach(function(card) {
      var toggle = card.querySelector('.belief-card__toggle');
      var details = card.querySelector('.belief-card__details');
      if (!toggle || !details) return;

      toggle.addEventListener('click', function() {
        var expanded = this.getAttribute('aria-expanded') === 'true';
        this.setAttribute('aria-expanded', String(!expanded));
        this.textContent = expanded ? 'Explore this position' : 'Hide details';
        details.hidden = expanded;
      });
    });

    if (searchInput) {
      searchInput.addEventListener('input', applyFilters);
    }

    applyFilters();
  })();
</script>
