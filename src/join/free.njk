---
title: Continue to Free Membership
layout: default
permalink: /join/free/
destinationUrl: https://eepurl.com/bdyIg5
membershipType: free
---

<section class="fh5co-section">
  <div class="container">
    <div class="row">
      <div class="col-md-8 col-md-offset-2 text-center">
        <h1>Continue to free membership</h1>
        <p>You are being sent to the Christian Transhumanist Association signup form.</p>
        <p><a class="btn btn-primary btn-lg" href="{{ destinationUrl }}" id="membership-continue">Continue</a></p>
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    var continueLink = document.getElementById("membership-continue");
    if (!continueLink) return;

    continueLink.addEventListener("click", function (event) {
      if (!window.ctaReportMembershipConversion) return;

      event.preventDefault();
      if (continueLink.getAttribute("aria-disabled") === "true") return;
      continueLink.setAttribute("aria-disabled", "true");
      window.ctaReportMembershipConversion(continueLink.href, "{{ membershipType }}");
    });
  })();
</script>
