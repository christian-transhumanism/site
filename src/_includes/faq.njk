---
title: Frequently Asked Questions
description: Questions that everyone will be asking in the future
layout: resourcePage
---

<h1>Frequently Asked Questions</h1>
<section id="fh5co-faqs">
  <div class="faq-toolbar">
    <input type="search" id="faq-search" class="form-control input-sm" placeholder="Search FAQs..." aria-label="Search FAQs">
    <div class="btn-group btn-group-sm" role="group" aria-label="FAQ controls">
      <button type="button" id="faq-collapse-all" class="btn btn-default">Collapse All</button>
      <button type="button" id="faq-expand-all" class="btn btn-primary">Expand All</button>
    </div>
  </div>
  <div class="faq-empty alert alert-info" style="display:none;">No matching questions.</div>
  <ul class="faq-list">
  {% for faq in faqs %}
    <li class="faq-item" role="group">
      <button type="button" class="faq-question" id="q-{{ loop.index }}" aria-controls="a-{{ loop.index }}" aria-expanded="false">
        <span class="faq-question-text">{{ faq.question | mdInline | wikilinks | safe }}</span>
        <span class="faq-question-icon" aria-hidden="true">
          <i class="glyphicon glyphicon-chevron-down"></i>
        </span>
      </button>
      <div class="faq-body" id="a-{{ loop.index }}" role="region" aria-labelledby="q-{{ loop.index }}">
        {{ faq.answer | md | wikilinks | safe }}
      </div>
    </li>
  {% endfor %}
  </ul>
</section>

<script>
  (function(){
    var container = document.getElementById('fh5co-faqs');
    var expandAll = document.getElementById('faq-expand-all');
    var collapseAll = document.getElementById('faq-collapse-all');
    var searchInput = document.getElementById('faq-search');
    var emptyMsg = container.querySelector('.faq-empty');

    function setButtons(state){
      expandAll.className = 'btn ' + (state === 'expanded' ? 'btn-primary' : 'btn-default');
      collapseAll.className = 'btn ' + (state === 'collapsed' ? 'btn-primary' : 'btn-default');
    }

    function getVisibleItems(){
      return Array.prototype.filter.call(container.querySelectorAll('.faq-item'), function(el){
        return el.style.display !== 'none';
      });
    }

    function updateToolbarState(){
      var items = getVisibleItems();
      if (!items.length) { setButtons('collapsed'); return; }
      var expanded = items.filter(function(el){ return el.classList.contains('active'); }).length;
      if (expanded === 0) setButtons('collapsed');
      else if (expanded === items.length) setButtons('expanded');
      else { setButtons('partial'); }
    }

    function toggle(item, expand){
      var isActive = item.classList.contains('active');
      var doExpand = (typeof expand !== 'undefined') ? expand : !isActive;
      item.classList.toggle('active', doExpand);
      item.querySelector('.faq-question').setAttribute('aria-expanded', doExpand);
    }

    container.addEventListener('click', function(e){
      var btn = e.target.closest('.faq-question');
      if (btn) { toggle(btn.closest('.faq-item')); updateToolbarState(); }
    });

    expandAll.addEventListener('click', function(){
      getVisibleItems().forEach(function(el){ toggle(el, true); });
      updateToolbarState();
    });

    collapseAll.addEventListener('click', function(){
      getVisibleItems().forEach(function(el){ toggle(el, false); });
      updateToolbarState();
    });

    searchInput.addEventListener('input', function(){
      var q = this.value.toLowerCase().trim();
      var any = false;
      container.querySelectorAll('.faq-item').forEach(function(item){
        var text = (item.querySelector('.faq-question-text').textContent + ' ' + item.querySelector('.faq-body').textContent).toLowerCase();
        var match = q === '' || text.indexOf(q) !== -1;
        item.style.display = match ? '' : 'none';
        if (match) any = true;
      });
      emptyMsg.style.display = any ? 'none' : '';
      updateToolbarState();
    });

    updateToolbarState();
  })();
</script>
