<head>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{% if title %}{{ title }} | {{ site.sitename or 'Christian Transhumanist Association' }}{% else %}{{ site.title or 'Christian Transhumanist Association: Faith, Technology, and the Future' }}{% endif %}</title>

<meta name="google-site-verification" content="FTJq_oBL1CX0ZjEkvySnzTPhb4HtdWIXDGWgDqoALFU" />
<meta name="description"              content="{{ description or site.description }}" />
<meta property="url"                  content="{{ site.url }}" />
<meta name="twitter:site"             content="{{ site.creator }}" />
<meta name="twitter:creator"          content="{{ site.creator }}" />
<meta name="twitter:title"            content="{{ title or site.title }}" />
<meta name="twitter:description"      content="{{ description or site.description }}" />
<meta name="twitter:image"            content="{{ site.image }}" />
<meta property="og:description"       content="{{ description or site.description }}" />
<meta property="og:site_name"         content="{{ site.sitename or site.title }}" />
<meta property="og:title"             content="{{ title or site.title }}" />
<meta property="og:type"              content="{{ site.type or 'website' }}" />
<meta property="og:image"             content="{{ site.image }}" />
<meta property="fb:app_id"            content="{{ site.app_id }}" />
{% if metaRobots %}
<meta name="robots"                   content="{{ metaRobots }}" />
{% endif %}
<link rel="canonical" href="{{ site.url }}{{ page.url }}" />
<link rel="alternate" type="application/atom+xml" title="{{ site.sitename or 'Christian Transhumanist Association' }}" href="{{ site.url }}/feed.xml" />

{% if page.url == "/" %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "{{ site.sitename }}",
  "url": "{{ site.url }}",
  "logo": {
    "@type": "ImageObject",
    "url": "{{ site.image }}"
  }
}
</script>
{% endif %}

<link rel="apple-touch-icon" sizes="57x57" href="/assets/icons/apple-icon-57x57.png">
<link rel="apple-touch-icon" sizes="60x60" href="/assets/icons/apple-icon-60x60.png">
<link rel="apple-touch-icon" sizes="72x72" href="/assets/icons/apple-icon-72x72.png">
<link rel="apple-touch-icon" sizes="76x76" href="/assets/icons/apple-icon-76x76.png">
<link rel="apple-touch-icon" sizes="114x114" href="/assets/icons/apple-icon-114x114.png">
<link rel="apple-touch-icon" sizes="120x120" href="/assets/icons/apple-icon-120x120.png">
<link rel="apple-touch-icon" sizes="144x144" href="/assets/icons/apple-icon-144x144.png">
<link rel="apple-touch-icon" sizes="152x152" href="/assets/icons/apple-icon-152x152.png">
<link rel="apple-touch-icon" sizes="180x180" href="/assets/icons/apple-icon-180x180.png">
<link rel="icon" type="image/x-icon" href="/assets/icons/favicon.ico">
<link rel="icon" type="image/png" sizes="192x192"  href="/assets/icons/android-icon-192x192.png">
<link rel="icon" type="image/png" sizes="32x32" href="/assets/icons/favicon-32x32.png">
<link rel="icon" type="image/png" sizes="96x96" href="/assets/icons/favicon-96x96.png">
<link rel="icon" type="image/png" sizes="16x16" href="/assets/icons/favicon-16x16.png">
<link rel="manifest" href="/assets/icons/manifest.json">
<meta name="msapplication-TileColor" content="#f5f7fb">
<meta name="msapplication-TileImage" content="/assets/icons/ms-icon-144x144.png">
<meta name="theme-color" content="#f5f7fb">

<script>
  (function () {
    var storageKey = "cta-theme";
    var defaultTheme = "light";
    var theme = defaultTheme;
    var homeMessaging = "default";

    try {
      var storedTheme = window.localStorage.getItem(storageKey);
      if (storedTheme === "light" || storedTheme === "dark") {
        theme = storedTheme;
      }
    } catch (error) {}

    if (window.location.pathname === "/") {
      try {
        var messaging = new URLSearchParams(window.location.search).get("messaging");
        if (messaging === "expansive-futures") {
          homeMessaging = messaging;
        }
      } catch (error) {}
    }

    document.documentElement.setAttribute("data-theme", theme);
    document.documentElement.setAttribute("data-home-messaging", homeMessaging);

    var themeColor = theme === "dark" ? "#070b13" : "#f5f7fb";
    var themeMeta = document.querySelector('meta[name="theme-color"]');
    if (themeMeta) {
      themeMeta.setAttribute("content", themeColor);
    }
    var tileMeta = document.querySelector('meta[name="msapplication-TileColor"]');
    if (tileMeta) {
      tileMeta.setAttribute("content", themeColor);
    }
  })();
</script>

<link rel="stylesheet" media="all" href="/stylesheets/bootstrap-compat.css">
<link rel="stylesheet" media="all" href="/stylesheets/all.css">
<link rel="stylesheet" media="all" href="/stylesheets/home-highlights.css">

<script>
  (function(i,s,o,g,r,a,m){i['GoogleAnalyticsObject']=r;i[r]=i[r]||function(){
  (i[r].q=i[r].q||[]).push(arguments)},i[r].l=1*new Date();a=s.createElement(o),
  m=s.getElementsByTagName(o)[0];a.async=1;a.src=g;m.parentNode.insertBefore(a,m)
  })(window,document,'script','https://www.google-analytics.com/analytics.js','ga');

  ga('create', 'UA-98633264-1', 'auto');
  ga('send', 'pageview');
</script>
</head>
