{% set highlights = [
  {
    url: '/blog/2025-noland-arbaugh-neuralink/',
    heading: "Did you know the world's first Neuralink recipient is a devout Christian?…",
    image: 'https://res.cloudinary.com/christian-transhumanist-association/image/upload/v1751292628/noland-arbaugh-1.png',
    headingClass: null,
    useOriginal: true,
    modifier: 'home-highlight--fit'
  },
  {
    url: '/mission/theological/creation-mandate/',
    heading: 'The Creation Mandate: Why Christianity Entails Ruling the Cosmos',
    image: 'https://res.cloudinary.com/christian-transhumanist-association/image/upload/v1760147651/Gemini_Generated_Image_oto6n1oto6n1oto6_v7rj5u.png',
    headingClass: 'home-highlight__heading--large',
    contentClass: 'home-highlight__content--wide',
    modifier: 'home-highlight--top',
    transform: 'c_fill,g_auto,w_1600,h_960,f_auto,q_auto,dpr_auto'
  },
  {
    url: '/blog/2025-religion-essential-to-the-future/',
    heading: "Religion is essential to the future",
    subheading: "If you care about outcomes, you can't ignore the most successful social technology in human history.",
    image: 'https://res.cloudinary.com/christian-transhumanist-association/image/upload/v1659056646/great-is-truth-and-mighty-above-all-things.png',
    transform: 'c_fill,g_auto,w_1200,h_720,f_auto,q_auto,dpr_auto'
  }
] %}

<section class="home-highlights">
  <div class="container">
    <div class="home-highlights__grid">
      {% for feature in highlights %}
      {% set transform = feature.transform %}
      {% if (not transform) and (not feature.useOriginal) %}
        {% set transform = 'c_fill,g_auto,w_1600,h_960,f_auto,q_auto,dpr_auto' %}
      {% endif %}
      {% if transform %}
        {% set highlightImage = feature.image | cdnImage(transform) %}
      {% else %}
        {% set highlightImage = feature.image %}
      {% endif %}
      <a
        class="home-highlight{% if feature.modifier %} {{ feature.modifier }}{% endif %}"
        href="{{ feature.url }}"
      >
        <span class="home-highlight__media" aria-hidden="true">
          <img src="{{ highlightImage }}" alt="" loading="lazy">
        </span>
        <div class="home-highlight__content{% if feature.contentClass %} {{ feature.contentClass }}{% endif %}">
          <h3 class="home-highlight__heading{% if feature.headingClass %} {{ feature.headingClass }}{% endif %}">{{ feature.heading }}</h3>
          {% if feature.subheading %}
          <p class="home-highlight__subheading">{{ feature.subheading }}</p>
          {% endif %}
        </div>
      </a>
      {% endfor %}
    </div>
  </div>
</section>
