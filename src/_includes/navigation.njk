<!-- navigation styled for Bootstrap 3.0 //-->
<nav class="navbar navbar-default navbar-fixed-top site-nav" aria-label="Primary">
  <div class="container site-nav__container">
    <div class="navbar-header site-nav__bar">
      <a href="/" class="site-nav__brand" aria-label="Christian Transhumanist Association home">
        <img src="//res.cloudinary.com/christian-transhumanist-association/image/upload/c_scale,h_40/v1757077096/CTA_Logo_-_Light_Background_dlzadg.png" alt="Christian Transhumanist Association"/>
      </a>
      <button
        type="button"
        class="navbar-toggle site-nav__toggle"
        data-toggle="collapse"
        data-target="#site-primary-nav"
        aria-controls="site-primary-nav"
        aria-expanded="false"
        aria-label="Open site navigation"
      >
        <span class="sr-only">Toggle navigation</span>
        <span class="icon-bar"></span>
        <span class="icon-bar"></span>
        <span class="icon-bar"></span>
      </button>
    </div>
    <button type="button" class="site-nav__backdrop" data-nav-backdrop hidden tabindex="-1" aria-hidden="true"></button>
    <div id="site-primary-nav" class="collapse navbar-collapse site-nav__panel" aria-hidden="true">
      <ul class="nav navbar-nav site-nav__list">
        {% include '_navigation_links.njk' %}
      </ul>
      <ul class="nav navbar-nav navbar-right site-nav__list site-nav__list--secondary">
        <li>
          <a
            href="/saved/"
            class="site-nav__icon-link site-saved-link"
            data-saved-pages-link
            aria-label="View saved pages"
            title="View saved pages"
          >
            <svg class="site-nav__icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M7 4.75h10a1.25 1.25 0 0 1 1.25 1.25v14.25l-6.25-3.55-6.25 3.55V6A1.25 1.25 0 0 1 7 4.75Z" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"/>
            </svg>
            <span class="site-saved-link__count" data-saved-pages-count>0</span>
            <span class="sr-only">Saved pages</span>
          </a>
        </li>
        <li>
          <button
            type="button"
            class="site-theme-toggle site-nav__icon-link"
            data-theme-toggle
            aria-pressed="false"
            aria-label="Switch to dark mode"
          >
            <svg class="site-theme-toggle__icon site-nav__icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <g class="site-theme-toggle__rays" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.8">
                <path d="M12 1.5v3"/>
                <path d="M4.95 4.95 7.1 7.1"/>
                <path d="M1.5 12h3"/>
                <path d="M19.05 4.95 16.9 7.1"/>
                <path d="M19.5 12h3"/>
              </g>
              <path class="site-theme-toggle__bulb" d="M10 18.25h4m-3 2.25h2m-3.95-6.55A5.35 5.35 0 0 1 6.9 9.7 5.1 5.1 0 0 1 12 4.65a5.1 5.1 0 0 1 5.1 4.95 5.42 5.42 0 0 1-2.15 4.4c-.72.54-1.17 1.36-1.23 2.26V17h-3.44v-.74c-.07-.9-.52-1.72-1.23-2.31Z" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"/>
            </svg>
            <span class="sr-only">Theme</span>
          </button>
        </li>
        {% include '_navigation_links_right.njk' %}
      </ul>
    </div>
  </div>
</nav>
